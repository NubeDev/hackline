{
  "name": "@hackline/client",
  "version": "0.1.0",
  "description": "TypeScript client for the hackline gateway REST + SSE surface, plus the Rust-generated wire types.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NubeDev/hackline.git",
    "directory": "clients/hackline-ts"
  },
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "import": "./dist/wire.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "~5.8.3",
    "vitest": "^2.1.9"
  }
}
